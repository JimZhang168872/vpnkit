[Unit]
Description=mihomo proxy core (managed by vpnkit)
After=network-online.target
Wants=network-online.target
StartLimitBurst=3
StartLimitIntervalSec=30

[Service]
Type=simple
{{- range .ProxyEnv}}
Environment="{{.}}"
{{- end}}
ExecStart={{.Binary}} -d {{.ConfigDir}}
Restart=on-failure
RestartSec=5s
LimitNOFILE=1048576

[Install]
WantedBy=default.target
